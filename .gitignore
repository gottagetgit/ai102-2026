.env
*.env
.env.local
.env.*.local
secrets.json
credentials.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# --- Virtual environments ---
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
.conda/

# --- Build / distribution ---
build/
dist/
*.egg-info/
*.egg
*.whl
MANIFEST
.eggs/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Testing ---
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
*.log

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Azure / Prompt Flow artifacts ---
.promptflow/
.runs/
promptflow_logs/
*.pf.yaml.lock

# --- Semantic Kernel ---
.sk/
sk_workdir/

