# AI-102 Demo Repository — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
#
# Get these values from:
#   - Azure Portal > your resource > Keys and Endpoint
#   - Azure AI Foundry: https://ai.azure.com/
#   - Azure CLI: az cognitiveservices account show --name <name> -g <rg>

# =============================================================================
# Azure Subscription / General
# =============================================================================
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_REGION=eastus

# =============================================================================
# Microsoft Entra ID (Service Principal for non-interactive auth)
# Used by: domain1/authenticate_entra.py
# Create with: az ad sp create-for-rbac --name ai102-demo
# =============================================================================
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-service-principal-client-id
AZURE_CLIENT_SECRET=your-service-principal-secret

# =============================================================================
# Azure AI Services (multi-service resource)
# Used by: domain6/search_create_index.py, content_understanding.py
# =============================================================================
AZURE_AI_SERVICES_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_AI_SERVICES_KEY=your-ai-services-key

# =============================================================================
# Azure OpenAI
# Used by: domain2/, domain3/, domain6/search_semantic_vector.py
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_CHAT_DEPLOY=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOY=text-embedding-3-small
AZURE_OPENAI_IMAGE_DEPLOY=dall-e-3

# =============================================================================
# Azure AI Foundry / AI Projects
# Used by: domain3/ (agentic AI)
# Get from: https://ai.azure.com/ > your project > Overview
# =============================================================================
AZURE_AI_PROJECT_ENDPOINT=https://your-project.api.azureml.ms/
AZURE_AI_PROJECT_NAME=your-project-name

# =============================================================================
# Azure AI Search
# Used by: domain6/search_*.py
# =============================================================================
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_ADMIN_KEY=your-search-admin-key
AZURE_SEARCH_QUERY_KEY=your-search-query-key
AZURE_SEARCH_INDEX_NAME=ai102-demo-index

# =============================================================================
# Azure Storage
# Used by: domain6/search_create_index.py, search_knowledge_store.py
# Connection string from: Storage Account > Access keys
# =============================================================================
AZURE_STORAGE_CONNECTION_STR=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=documents

# =============================================================================
# Azure Document Intelligence (formerly Form Recognizer)
# Used by: domain6/document_intelligence_*.py
# =============================================================================
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key

# Custom model training data (SAS URL to labeled blob container)
# Generate with: az storage container generate-sas --permissions rl ...
AZURE_TRAINING_CONTAINER_SAS_URL=https://youraccount.blob.core.windows.net/training-data?sv=...sas-token

# Custom model IDs (set after training in Document Intelligence Studio)
AZURE_CUSTOM_MODEL_ID=my-custom-invoice-model
AZURE_CUSTOM_MODEL_ID_2=my-custom-receipt-model
AZURE_COMPOSED_MODEL_ID=my-composed-model

# =============================================================================
# Azure AI Language
# Used by: domain5/ (sentiment, NER, key phrases, CLU, QnA, etc.)
# =============================================================================
AZURE_LANGUAGE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=your-language-key

# Conversational Language Understanding (CLU)
AZURE_CLU_PROJECT_NAME=your-clu-project
AZURE_CLU_DEPLOYMENT_NAME=production

# Custom Question Answering
AZURE_QA_PROJECT_NAME=your-qna-project
AZURE_QA_DEPLOYMENT_NAME=production

# =============================================================================
# Azure AI Speech
# Used by: domain5/speech_*.py, ssml_speech.py, text_to_speech.py
# =============================================================================
AZURE_SPEECH_KEY=your-speech-key
AZURE_SPEECH_REGION=eastus

# =============================================================================
# Azure AI Vision
# Used by: domain4/image_analysis.py, ocr_read_text.py, handwriting_recognition.py
# =============================================================================
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_VISION_KEY=your-vision-key

# Custom Vision (Training)
AZURE_CUSTOM_VISION_TRAINING_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_CUSTOM_VISION_TRAINING_KEY=your-custom-vision-training-key

# Custom Vision (Prediction)
AZURE_CUSTOM_VISION_PREDICTION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_CUSTOM_VISION_PREDICTION_KEY=your-custom-vision-prediction-key
AZURE_CUSTOM_VISION_PROJECT_ID=your-project-guid
AZURE_CUSTOM_VISION_PUBLISH_NAME=Iteration1

# =============================================================================
# Azure AI Content Safety
# Used by: domain1/content_safety.py, content_filters_blocklists.py, prompt_shields.py
# =============================================================================
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=your-content-safety-key

# =============================================================================
# Azure AI Translator
# Used by: domain5/text_translation.py, document_translation.py
# =============================================================================
AZURE_TRANSLATOR_KEY=your-translator-key
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/
AZURE_TRANSLATOR_REGION=eastus

# Document Translation (requires Storage blobs for source/target)
AZURE_DOCUMENT_TRANSLATOR_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_TRANSLATION_SOURCE_SAS_URL=https://youraccount.blob.core.windows.net/source?sas-token
AZURE_TRANSLATION_TARGET_SAS_URL=https://youraccount.blob.core.windows.net/target?sas-token

# =============================================================================
# Custom Skill (Azure Function endpoint for Domain 6)
# Used by: domain6/search_custom_skill.py
# =============================================================================
AZURE_CUSTOM_SKILL_URL=https://your-function-app.azurewebsites.net/api/custom-skill
AZURE_FUNCTION_KEY=your-function-host-key
